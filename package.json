{
  "name": "mern-stack",
  "version": "1.0.0",
  "description": "MERN stack template",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client start",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "build": "npm --prefix client run build",
    "test:server": "npm --prefix server test",
    "test:client": "npm --prefix client test --watchAll=false"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
